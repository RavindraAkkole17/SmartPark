## Database Schema Design

### Users Collection
```javascript
{
  _id: ObjectId,
  name: String,
  email: String (unique),
  password: String (hashed),
  phone: String,
  role: "admin" | "user",
  createdAt: Date
}
```

### ParkingAreas Collection
```javascript
{
  _id: ObjectId,
  adminId: ObjectId (ref: Users),
  name: String,
  location: {
    address: String,
    lat: Number,
    lng: Number
  },
  cctvUrl: String,
  totalSlots: Number,
  pricePerHour: Number,
  createdAt: Date
}
```

### Slots Collection
```javascript
{
  _id: ObjectId,
  parkingAreaId: ObjectId (ref: ParkingAreas),
  slotNumber: String,           // e.g., "A1", "A2"
  coordinates: [                // Polygon coordinates drawn by admin
    { x: Number, y: Number }
  ],
  status: "empty" | "occupied" | "reserved",
  currentBookingId: ObjectId (ref: Bookings, nullable),
  updatedAt: Date
}
```

### Bookings Collection
```javascript
{
  _id: ObjectId,
  userId: ObjectId (ref: Users),
  parkingAreaId: ObjectId (ref: ParkingAreas),
  slotId: ObjectId (ref: Slots),
  bookingDate: Date,            // The date for which slot is booked
  paymentId: String,            // Razorpay payment ID
  orderId: String,              // Razorpay order ID
  amount: Number,
  status: "confirmed" | "completed" | "cancelled",
  createdAt: Date
}
```

